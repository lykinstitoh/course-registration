APP_NAME="OCRS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost
FORCE_HTTPS=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=course_registration
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="registrar@institution.ac.ke"

OCRS_INSTITUTION_NAME="Private University College"
OCRS_INSTITUTION_CODE="PUC"
OCRS_SUPPORT_EMAIL="registrar@institution.ac.ke"
OCRS_SUPPORT_PHONE="+254700000000"
OCRS_DATA_RETENTION_YEARS=7

MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Use a full public HTTPS URL on Railway (do not rely on ${APP_URL} in the Railway dashboard).
# Example: https://your-app.up.railway.app/api/mpesa/stk-callback
MPESA_CALLBACK_URL=
MPESA_CONFIRMATION_URL=
MPESA_VALIDATION_URL=
MPESA_ENVIRONMENT=sandbox
MPESA_TIMEOUT=30

AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=
AFRICASTALKING_SENDER_ID=OCRS
AFRICASTALKING_ENVIRONMENT=sandbox
